def main() -> None:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Git Auto Committer - Generate commit messages using Ollama",
        add_help=False
    )
    
    parser.add_argument(
        "-m", "--model",
        default=get_default_model(),
        help=f"Ollama model to use (default: {DEFAULT_MODEL})"
    )
    
    parser.add_argument(
        "--no-push",
        action="store_false",
        dest="push",
        default=True,
        help="Don't push after committing"
    )
    
    parser.add_argument(
        "-r", "--remote",
        default=DEFAULT_REMOTE,
        help=f"Remote to push to (default: {DEFAULT_REMOTE})"
    )
    
    parser.add_argument(
        "--ollama-url",
        default=DEFAULT_OLLAMA_URL,
        help=f"Ollama API URL (default: {DEFAULT_OLLAMA_URL})"
    )
    
    parser.add_argument(
        "-b", "--branch",
        default=None,
        help="Branch to push (default: current branch)"
    )
    
    parser.add_argument(
        "--install",
        action="store_true",
        help="Install autocommit to system PATH"
    )
    
    parser.add_argument(
        "--select-model",
        action="store_true",
        help="Show available Ollama models and select default"
    )
    
    parser.add_argument(
        "-h", "--help",
        action="store_true",
        help="Show help message"
    )
    
    parser.add_argument(
        "-v", "--version",
        action="store_true",
        help="Show version"
    )
    
    parser.add_argument(
        "-y", "--yes",
        action="store_true",
        default=False,
        help="Skip confirmation and auto-accept commit"
    )
    
    parser.add_argument(
        "--tag",
        default=None,
        metavar="VERSION",
        help="Create an annotated git tag (e.g. v1.2.6 or 1.2.6)"
    )
    
    parser.add_argument(
        "--release",
        action="store_true",
        default=False,
        help="Publish a GitHub release via gh CLI (requires --tag)"
    )
    
    parser.add_argument(
        "--release-notes",
        default=None,
        metavar="TEXT",
        help="Custom release notes (omit for AI-generated notes)"
    )
    
    parser.add_argument(
        "--draft",
        action="store_true",
        default=False,
        help="Create the GitHub release as a draft"
    )
    
    parser.add_argument(
        "--prerelease",
        action="store_true",
        default=False,
        help="Mark the GitHub release as a pre-release"
    )
    
    parser.add_argument(
        "--no-tag-push",
        action="store_true",
        default=False,
        help="Create the tag locally without pushing it"
    )
    
    # Parse arguments
    args, unknown = parser.parse_known_args()
    
    if args.version:
        print(f"autocommit v{VERSION}")
        sys.exit(0)
    
    if args.help or unknown:
        show_help()
        sys.exit(0 if args.help else 1)
    
    # Handle install flag
    if args.install:
        success = install_to_path()
        sys.exit(0 if success else 1)
    
    # Handle select-model flag
    if args.select_model:
        success = select_model()
        sys.exit(0 if success else 1)
    
    # Validate flag combinations
    if args.release and not args.tag:
        log_error("--release requires --tag to specify a version")
        sys.exit(1)
    
    if args.draft and not args.release:
        log_warning("--draft has no effect without --release")
    
    if args.prerelease and not args.release:
        log_warning("--prerelease has no effect without --release")
    
    if args.release_notes and not args.release:
        log_warning("--release-notes has no effect without --release")
    
    try:
        committer = GitAutoCommitter(
            model=args.model,
            ollama_url=args.ollama_url
        )
        
        success = committer.run(
            push=args.push,
            remote=args.remote,
            branch=args.branch,
            auto_accept=args.yes,
            tag_version=args.tag,
            release=args.release,
            release_notes=args.release_notes,
            draft=args.draft,
            prerelease=args.prerelease,
            no_tag_push=args.no_tag_push
        )
        
        sys.exit(0 if success else 1)
        
    except KeyboardInterrupt:
        log_error("Operation cancelled by user")
        sys.exit(1)
    except Exception as e:
        log_error(f"Unexpected error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
